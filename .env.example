# Kafka connection
KAFKA_BOOTSTRAP_SERVER=pkc-z3p1v0.europe-west2.gcp.confluent.cloud:9092
KAFKA_USERNAME=<your api key>
KAFKA_PASSWORD=<your api secret>
KAFKA_CONSUMER_GROUP=<your consumer group id>

# Rolling window eviction parameters
WINDOW_MAX_MESSAGES_PER_SERVICE=10
WINDOW_MAX_AGE_MINUTES=240

# Phase 1: timed ingest duration in seconds (set to 0 for continuous/Phase 2 mode)
PHASE1_INGEST_SECONDS=120

# Optional: path to reference data directory (defaults to current working directory)
# REFERENCE_DATA_DIR=./Reference data
